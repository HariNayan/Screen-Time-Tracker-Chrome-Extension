{
  "manifest_version": 3,
  "name": "Screen Time Tracker",
  "version": "1.0.0",
  "description": "A privacy-first Chrome extension that tracks time spent per domain using only local storage, with zero network calls.",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "idle",
    "downloads"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
